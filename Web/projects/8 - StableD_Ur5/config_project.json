    "project": {
        "title": "StableDiffusion to gcode - UR5e",
        "subtitle": "Códigos Gcode para UR5e",
        "shortDescription": "Generación de imágenes con IA y su conversión a Gcode para planificación de trayectorias de robot UR5e",
        "fullDescription": "Se generan imágenes mediante IA con StableDiffusion, se capturan los prompts y mejoran con DeepSeek y se convierten a Gcode para ser interpretadas por un robot UR5e, permitiendo la planificación de trayectorias basadas en imágenes generadas por IA.",
        "status": "Completado",
        "year": "2025",
        "duration": "3 meses",
