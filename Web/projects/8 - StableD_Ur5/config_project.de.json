    "project": {
        "title": "StableDiffusion to gcode - UR5e",
        "subtitle": "G-Code für UR5e",
        "shortDescription": "KI-Bilderzeugung und Konvertierung in G-Code für die Bahnplanung eines UR5e-Roboters",
        "fullDescription": "Images are generated with StableDiffusion, prompts are captured and improved with DeepSeek, and the results are converted to G-code for a UR5e robot, enabling trajectory planning from AI-generated images.",
