    "project": {
        "title": "StableDiffusion to gcode - UR5e",
        "subtitle": "G-Code für UR5e",
        "shortDescription": "KI-Bilderzeugung und Konvertierung in G-Code für die Bahnplanung eines UR5e-Roboters",
        "fullDescription": "Se generan imágenes mediante IA con StableDiffusion, se capturan los prompts y mejoran con DeepSeek y se convierten a Gcode para ser interpretadas por un robot UR5e, permitiendo la planificación de trayectorias basadas en imágenes generadas por IA.",
        "status": "Abgeschlossen",
        "year": "2025",
        "duration": "3 Monate",
        "team": [
            "José Pablo Hernández Alonso"
        ],
        "tags": [
            "Robotik",
            "Robótica Colaborativa",
            "Automatisierung",
            "Gcode",
            "UR5e",
            "IA/ML",
            "Computer Vision"
        ],
        "repository": "https://github.com/JPHAJP/StableDiffusion_t_gcode",
        "documentation": "https://jphajp.github.io/Robotica/Web/Reportes/Laboratorio/Proy_final/assets/Media/Reporte%20de%20uso%20interfaz%20UR5e-Artista%201.pdf"
    },
    "overview": {
        "problem": "La conversión de imágenes a Gcode para la planificación de trayectorias de robots es un proceso complejo que requiere una alta precisión y adaptación a diferentes entornos de trabajo.",
        "solution": "Se propone un sistema que utiliza IA para generar imágenes y convertirlas a Gcode, optimizando así la planificación de trayectorias.",
        "impact": "Este enfoque permitirá una mayor flexibilidad y eficiencia en la programación de robots UR5e."
    },
