    "project": {
        "title": "Ur5-Scrub-Nurse - S.I.L.V.I.A.",
        "subtitle": "Surgical Instrument Logistics Virtual Intelligent Assistant",
        "shortDescription": "KI-gestützter kollaborativer Roboter zur Unterstützung chirurgischer Instrumentierung",
        "fullDescription": "Fortschrittliches Robotersystem, das mehrere KI-Technologien kombiniert, um die Assistenz bei chirurgischen Verfahren zu automatisieren.",
